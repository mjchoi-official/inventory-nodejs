# ─── SSH 터널 설정 ───────────────────────
SSH_HOST=inedeath.cafe24.com
SSH_PORT=22
SSH_USER=root
SSH_KEY_PATH=ssh-key.pem
# SSH_PASSWORD=your-ssh-password   # 키 대신 패스워드 사용 시

# ─── MariaDB 설정 ────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=inventory
TUNNEL_PORT=13306

# ─── JWT 설정 ────────────────────────────
JWT_SECRET=your-super-secret-key-change-this   # 반드시 변경!
JWT_EXPIRES=7d

# ─── 서버 설정 ────────────────────────────
PORT=3000
